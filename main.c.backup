						unordered_list_begin("margin-top: 15px; margin-bottom: 15px;");
							list_item("Completed: January, 2, 2026;", NULL);
							list_item("Score: 10/10;", NULL);
							list_item("Commentary: This book is a disruptive point in my life. I was reading it before"
