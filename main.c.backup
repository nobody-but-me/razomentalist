	// WRITING PAGE
	page_begin(&writing, &writing_conf);
		div_begin(FLEX_BEGIN_ROW"width: 100vw; height: auto;");
			chess_background();
			div_begin("min-width: 75%; max-width: 75%; width: 75%; height: 100%; overflow-y: scroll; overflow-x: hidden;"
					  "box-shadow: 3px 0px 15px 15px rgba(0,0,0,0.5); z-index: 5;");
				page_banner("books.jpg","writing banner", "credits: Still Life with Books, by "
							"<a href='https://en.wikipedia.org/wiki/Jan_Lievens' target='blank'>Jan Lievens.</a>");
div_begin("padding-left: 25px; padding-right: 25px;");
				div_begin(CENTER_SPACE_BETWEEN"width: 100%; border-bottom: 2px solid white;");
					header("Literature", ""); header("·", NULL); header("Literature", "transform: scaleX(-1);");
				div_end();
				div_begin(FLEX_BEGIN_ROW"height: 100%;");
					div_begin(CENTER_COLUMN"width: 100%; min-height: 100%;");
						div_begin(CENTER_ROW"width: 100%");
							para("\"And the sailor sat and rested. Intertwined the hairy fingers into his long beard and "
								 "looked at everything that was not his -- all of reality, in short, from the salty foam of "
								 "the suicidal waves to the clouds and their castles. Wore out the tired retinas all through"
								 " the environment and made himself present in the present, making the most of the unique instant"
								 " he, already in the winter of his life, has ever lived.",
							"width: 100%; text-align: justify;");
							empty_space("width: 30%;");
						div_end();
						div_begin(CENTER_ROW"width: 100%;");
							empty_space("width: 30%;");
							para("\"Got up. Stretched his body and described arc with the old spine. Shaped himself in fish, "
								 "raising the arms in a arrow. Jumped into the water and swam and felt the whole sun burned body "
								 "burning from the salt. He regurgitated himself from the air and reinvaginated into the warm "
								 "waves, swimming nearby obtuse stones, without fear, without reservations. He was and began to "
								 "be. And he smiled.\"",
							"width: 100%; text-align: justify;");
						div_end();
						div_begin(CENTER_ROW"width: 100%;");
							para("That's the literature room, where you can find some of my writing projects and some about what I am"
								" currently reading.",
							"width: 100%; text-align: justify;");
							empty_space("width: 30%");
						div_end();
						div_begin(CENTER_ROW"width: 100%;");
							empty_space("width: 30%;");
							para("Mostly of my texts are written in Portuguese, my native language, and they can range from "
								 "instrospective and biased thoughts on the reality of confused characters to drunks"
								 " peeing. Enjoy.",
							"width: 100%; text-align: justify;");
						div_end();
						div_begin(CENTER_ROW"width: 100%;");
							para("Also, noticing our reading time has decreased substantially, me and a friend of mine, Authoritarian"
								 " Venus, decided to engage in a reading project: we shall read one book a month for the whole "
								 "year, having rewards for reading extra books. I'll try to document here the books read.",
							"width: 100%; text-align: justify;");
							empty_space("width: 30%");
						div_end();
					div_end();
					image("the_sailor.png", "The Sailor", "width: 60%; height: auto; display: block; object-fit: contain;");
				div_end();
				div_begin(FLEX_BEGIN_ROW);
					header("One book a month, the project", NULL);
					header("&nbsp;&nbsp;·&nbsp;&nbsp;", NULL);
					header("One book a month, the project", "transform: scaleX(-1);");
				div_end();
				para("Here's the list of the books according to their month, as well as the extra books. By clicking on their "
					 "titles, you can see the date I completed them, the rating given, and a short commentary.",
				"width: 100%; text-align: justify;");
				unordered_list_begin(NULL);
					collapsible_list_item_begin(" >&nbsp;&nbsp;&nbsp;&nbsp; July: The Passion According to G.H., by "
												"Clarice Lispector;",
					"padding-top: 5px; paddingg-bottom: 5px;");
						unordered_list_begin("margin-top: 15px; margin-bottom: 15px;");
							list_item("Completed: July, 13, 2026;", NULL);
							list_item("Score: 08/10;", NULL);
							list_item("Commentary: I feel like I'll visit this book many times in the next few years."
									  " Many times while reading, I cross-dressed myself into G.H..",
							 NULL);
						unordered_list_end();
					collapsible_list_item_end();
					// SHHHHH
					collapsible_list_item_begin(" >&nbsp;&nbsp;&nbsp;&nbsp; June: The Bell Jar, by Sylvia Plath;"
												"<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;"
												"Frankenstein, by Mary Shelley;",
					"padding-top: 5px; padding-bottom: 5px;");
						unordered_list_begin("margin-top: 15px; margin-bottom: 15px;");
							list_item("Completed: June, 7, 2026;", NULL);
							list_item("Score: 08/10;", NULL);
							list_item("Commentary: another hard to swallow book. A type of coming-of-age book.", NULL);
						unordered_list_end();
						unordered_list_begin("padding-top: 15px; margin-bottom: 15px; border-top: 2px solid white;");
							list_item("Completed: June, 23, 2026;", NULL);
							list_item("Score: 10/10;", NULL);
							list_item("Commentary: an extra book for the month. And not \"a book\", but **the** book!"
									  " Frankenstein have been with me for longer than my own identity.",
							 NULL);
						unordered_list_end();
					collapsible_list_item_end();
					collapsible_list_item_begin(" >&nbsp;&nbsp;&nbsp;&nbsp; May: On the Road, Jack Kerouac;",
					"padding-top: 5px; padding-bottom: 5px;");
						unordered_list_begin("margin-top: 15px; margin-bottom: 15px;");
							list_item("Completed: May, 31, 2026;", NULL);
							list_item("Score: 05/10;", NULL);
							list_item("Commentary: I may have expected too much from the book? Loved the story, but it seems to "
									  "repeat itself over and over again, either in a desperate attempt by Kerouac to show what "
									  "it was like to be a beatnik, or for the sake of an extremely well detailed "
									  "semi-autobiographical novel. <br><br> On the Road is amazing, but I think it disappoints "
									  "by failing to develop the characters and by overlooking details and events that would have"
									  " been crazily fascinating in a complete fiction -- again, likely in an unnecessary effort "
									  "to make it as autobiographical as possible.",
							NULL);
						unordered_list_end();
					collapsible_list_item_end();
					collapsible_list_item_begin(" >&nbsp;&nbsp;&nbsp;&nbsp; April: Dry Lives, by Graciliano Ramos;",
					"padding-top: 5px; padding-bottom: 5px;");
						unordered_list_begin("margin-top: 15px; margin-bottom: 15px;");
							list_item("Completed: April, 5, 2026;", NULL);
							list_item("Score: 07/10;", NULL);
