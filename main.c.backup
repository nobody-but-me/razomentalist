#include <stdio.h>
#define CAROL_IMPLEMENTATION
#include "carol.h"

#define CENTER_COLUMN "display: flex; justify-content: center; flex-direction: column; align-items: center;"
#define CENTER_ROW    "display: flex; justify-content: center; flex-direction: row; align-items: center;"

#define CENTER_SPACE_AROUND "display: flex; justify-content: space-around; align-items: center;"
#define CENTER_SPACE_BETWEEN "display: flex; justify-content: space-between; align-items: center;"

#define FLEX_BEGIN_COLUMN "display: flex; justify-content: begin; flex-direction: column; align-items: begin;"
#define FLEX_END_COLUMN "display: flex; justify-content: end; flex-direction: column; align-items: end;"

#define FLEX_BEGIN_ROW "display: flex; justify-content: begin; flex-direction: row; align-items: begin;"
#define FLEX_END_ROW "display: flex; justify-content: end; flex-direction: row; align-items: end;"

#define ABSOLUTE_CENTER "position: absolute; top: 50%; left: 50%; translate: translate(-50%, -50%);"
#define RELATIVE_CENTER "position: relative; top: 50%; left: 50%; translate: translate(-50%, -50%);"

#define SOLID_BORDER(color) "border: 2px solid " #color ";"

static void return_index(void)
{
	div_begin(CENTER_SPACE_BETWEEN"margin-top: 15px; margin-bottom: 15px");
		para("[", NULL); hyperlink("./index.html", "Go Back To The Old House", NULL); para("]", NULL);
	div_end();
	return;
}

static void chess_background(void)
{
	div_begin("min-height: 100%; width: 100%; background-repeat: repeat; background-size: 100px 100px;"
			  "background-image: url(https://raw.githubusercontent.com/nobody-but-me/razomentalist/main/media/grid.png);"
			  "animation: texture_loop 10s linear infinite;"
			);
	div_end();
	return;
}

static void page_banner(const char*_image_path, const char*_alt, const char*_credits)
{
	div_begin("max-width: 100%; max-height: 150px; overflow: hidden; position: relative");
		image(_image_path, _alt, "width: 100%; height: auto; transform: translateY(-50%); display: block;");
		para(_credits,
		"color: white; position: absolute; top: 73%; left: 0%; z-index: 10; text-align: right; font-weight: bold;"
		"background-color: black; padding: 5px;");
	div_end();
	return;
}

static void button(const char*_link, const char*_image_path, const char*_alt)
{
	if (_link != NULL)
		link_image(_link, _image_path, _alt, "width: auto; margin: 5px;");
	else
		image(_image_path, _alt, "width: auto; margin: 5px;");
	return;
}

void carol_compose(void)
{
	page_conf index_conf, about_conf, writing_conf, neighbours_conf, journal_conf;
	page index, about, writing, neighbours, journal;
	
	create_configuration("Neighbours Room", get_var_name(neighbours), "index", &neighbours_conf);
	create_configuration("Literature Room", get_var_name(writing), "index", &writing_conf);
	create_configuration("As Gooffee As Me", get_var_name(index),"index",&index_conf);
	create_configuration("About Room", get_var_name(about), "index", &about_conf);
	create_configuration("Journal Room", get_var_name(journal), "index", &journal_conf);
	
	// JOURNAL PAGE
	page_begin(&journal, &journal_conf);
		div_begin(FLEX_BEGIN_ROW"width: 100vw; height: auto;");
			chess_background();
			div_begin("min-width: 75%; max-width: 75%; width: 75%; height: 100%; overflow-y: scroll; overflow-x: hidden;"
					  "box-shadow: 3px 0px 15px 15px rgba(0,0,0,0.5); z-index: 5;");
				page_banner("chakrasamvara_and_vajravarahi.png","neighbours banner", "credits: "
							"<a href='https://www.metmuseum.org/art/collection/search/78190' target='blank'>Chakrasamvara and Vajravarahi</a>");
div_begin("padding-left: 25px; padding-right: 25px;");
				div_begin(CENTER_SPACE_BETWEEN"width: 100%; border-bottom: 2px solid white;");
					header("Journal", ""); header("·", NULL); header("Journal", "transform: scaleX(-1);");
				div_end();
				div_begin(FLEX_BEGIN_ROW"height: 100%;");
					div_begin(CENTER_COLUMN"width: 100%; min-height: 100%;");
						div_begin(CENTER_ROW"width: 100%;");
							para("\"We liked to believe we could write. You were my Fernando Pessoa, I was your Mario de Sá "
								 "Carneiro; we lived in this kind of dynamic. Throughout some nights, we liked to spent hours "
								 "and hours sitting in front of each other, knee to knee, just to talk out loud about absolutely"
								 " anything that dared to come up our minds; we'd always end up in arguments about how biased the "
								 "human mind is, just for you to, in the end, fall asleep. For the rest of the night, I'd watch"
								 " you, as if scared of missing something out. So, then, right after the first greet of the dawn, I'd lie down upon "
								 "you as if I no longer knew  how to walk by my own legs and, as a child scared of the dark, "
								 "I'd hug you, sleeping right after.",
							"width: 100%; text-align: justify;");
							empty_space("width: 30%;");
						div_end();
						div_begin(CENTER_ROW"width: 100%;");
							empty_space("width: 30%;");
							para("\"The day I noticed I actually loved you were one of these mornings, where I, bleary-eyed, "
								 "started prepearing myself to go to sleep.",
							"width: 100%; text-align: justify;");
						div_end();
						div_begin(CENTER_ROW"width: 100%");
							para("\"Overlying your body lying "
								 "upon the bed, the hazy, foreign and unfamiliar sunlights from the bedroom window already "
								 "claimed the space beneath and amidst the layers of air filling the whole room, creating those "
								 "pretty sparkles that smell musty. The surrounding eiderdowns dunes largely concealed you, and "
								 "the trees outside rose up in monoliths, tattooing scattered shadows upon you as well as the "
								 "floor, covered with letterhead papers from the last night.",
							"width: 100%; text-align: justify;");
							empty_space("width: 30%;");
						div_end();
					div_end();
//					image("hurt.png", "f", "width: 50%; height: auto; display: block; object-fit: contain; margin: 15px;");
				div_end();
					div_begin(CENTER_ROW"width: 100%;");
						empty_space("width: 30%;");
						para("\"I got up and walked around a while; looked outside a few times, seeing nothing at all. I took then a "
							 "breath, collapsing in myself; felt, in the fall, the air rushing in, the pain in the lungs, my body "
							 "compressing itself into itself -- felt alive, in short, truly alive. ",
						"width: 100%; text-align: justify;");
					div_end();
					div_begin(CENTER_ROW"width: 100%; border-bottom: 2px solid white;");
						para("\"While I was falling into this intro-existence-specere, you woke up. I looked at you, scared as criminal caught red-"
							 "handed; you did the same, but with your almond in honey eyes, dewy by the sleep. Your pale skin "
							 "glowed and radiated in the cold morning sun, speaking the most intimate truths of you. "
							 "And so, personificationing itself, you, in the space of a few seconds, became the Silver Angel.\"",
						"width: 100%; text-align: justify;");
						empty_space("width: 30%;");
					div_end();
					div_begin(FLEX_BEGIN_ROW"width: 100%;");
						para("Here is my journal page. Unlike the <a href='./writing.html'>writing</a> page, which is going to have more "
							 "'literary-focused' texts, the texts here are going to be more essay/blog like, so expect to find "
							 "weird opinions, unrequested updates about anything really, and deliberately confusing texts. Enjoy.",
						"width: 100%; text-align: justify;");
					div_end();
				div_begin("width: 100%;");
					unordered_list_begin("border-top:");
						collapsible_list_item_begin(" >&nbsp;&nbsp;&nbsp;&nbsp;[July, 22, 2026] I am not afraid of learning anything.",
													"border-top: 2px solid white; padding-top: 15px; padding-bottom: 15px;");
							para("I only recently realized that there are people who are afraid of learning. Lots of them have this misconception"
								 " of 'there are things too hard or too complex to learn' -- and that's a very, very destructive"
								 " idea.",
							"width: 100%; text-align: justify;");
							para("Learning is the endless process of acquiring knowledge about anything. That is: "
								 "the life-long exercise of observating, "
								 "analysing and understanding reality beyond or inside us. It is the beautiful "
								 "act of becoming a child again and questioning \"where do these ants go to?\" or \"why "
								 "do carrots get soft in boiling water, but eggs don't?\". Nothing more.",
							"width: 100%; text-align: justify;");
							para("For some reason at some point I am still trying to understand, many people started to"
								 " believe that there are ideas or systems too complex to be learned, either because these"
								 " ideas and systems are widely considered \"hard\", or because these people subjectively"
								 " think these ideas and systems are too complex for them. Here I am going to briefly comment on two"
								 " questions: 1) are there ideas and systems that are \"too hard\" for certain people? And"
								 " 2) are there ideas and systems hard in essence?",
							"width: 100%; text-align: justify;");
							para("The first question falls pretty quickly: learning some system or idea is only hard for the "
								 "student doing so if, and only if, the student in question do not have the necessary background "
								 "knowledge required by that idea or system. It may sound arrogant, as if I mean \"students are "
								 "stupid and that's why things are hard for them\". No. Every knowledge requires a certain pior "
								 "knowledge: before riding a bike, you first had to learn how to walk on your own legs, thereby"
								 " developing sufficient balance for the bike; before learning objects fall when dropped, you "
								 "first had to watch them doing so. That's the whole process again and again: observation, analysing"
								 " and understanding.",
							"width: 100%; text-align: justify;");
							para("In my vision, mostly of the systems and ideas that seem too complex to be learned just need these "
								 "first steps, this background knowledge, this repertoire -- and that can be only acquired by "
								 "observating and analysing and understanding other less-verbose ideas and systems; a problem I "
								 "notice in people of my age -- including me here -- is that we often want to rush these first "
								 "essencial steps to jump as soon as possible to the result; this is self-destructive and just leads"
								 " to disappointment and dissatisfaction -- both with the oneself and with the subject in question."
								 " Learning is like building a house: it needs the designing, the preparation, the foundation and "
								 "framing, the rough-ins and the conclusions; if any step is skipped, the house will remain "
								 "incomplete, unusable.",
							"width: 100%; text-align: justify;");
							para("With that said: yes, ideas and systems are difficult for certain students, but it lasts only until"
								 " the student in question learns how to learn, acquiring, then, the necessary knowledge for that certain"
								 " subject. If today I try to play the drum, it is going to be pretty hard for me, but that happens "
								 "just because I have no prior experience with any percurssion musical instrument. What shouldn't "
								 "happen, thus, is for me to be afraid to learn the drums because of that. The repertoire will be "
								 "built with time and there are no reasons for me to believe I am uncapable of learning the drums;"
								 " before me, many humans did learn how to play that instrument, why wouldn't I? Someone before me"
								 " had the hard work not only to play the drums, but also the design them and make it \"playable\";"
								 " someone before me worked on the theory, the music and the techniques for other people to play "
								 "the drums, why wouldn't I be capable of wrapping my head around it? Thinking this way is "
								 "spectacular because, all of that I have once feared to learn quickly become just subjects to acquire"
								 " repertoire in, unexplored ideas and systems that I am not just going to try to understand, but will"
								 "understand exactly what it is about -- not in it's entirety, but that parts I am the most "
								 "the most"
							"width: 100%; text-align: justify;");
						collapsible_list_item_end();
						collapsible_list_item_begin(" >&nbsp;&nbsp;&nbsp;&nbsp;[July, 20, 2026] I like butter.",
													"border-top: 2px solid white; padding-top: 15px; padding-bottom: 15px;"
													"border-bottom: 2px solid white;");
							para("I like butter, always liked it. Perhaps the unique truth I can tell about myself is that"
								 " I like butter -- and I say so because all the people around me either were indifferent to "
								 "butter or didn't like it at all -- so if I always liked it, I am original on it -- and maybe "
								 "solely on it. I have being pioneer in liking butter, yes. Yes, yes, I like butter -- and the"
								 "truth that I write that is immeasurable. Perhaps I am performatic about everything I do, "
								 "like, and live -- but not, absolutely not, by any means, about liking butter.",
							"width: 100%; text-align: justify;");
						collapsible_list_item_end();
					unordered_list_end();
				div_end();
				return_index();
div_end();
			div_end();
		div_end();
	page_end();
	
	
